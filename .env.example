# Project Nautilus Environment Variables
# Copy this to .env and fill in your values
# DO NOT commit .env to git

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# NeMo Guardrails Configuration
NEMO_CONFIG_PATH=./config/rails

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# NeMo Guardrails Server (if running separately)
NEMO_SERVER_URL=http://localhost:8000
